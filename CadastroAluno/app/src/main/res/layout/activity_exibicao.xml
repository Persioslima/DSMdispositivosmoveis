<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Exibe o nome do aluno -->
    <TextView
        android:id="@+id/textViewStudentName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome do aluno:"
        android:textSize="18sp" />

    <!-- Exibe o número de matrícula -->
    <TextView
        android:id="@+id/textViewStudentId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Matrícula:"
        android:textSize="18sp"
        android:layout_marginTop="16dp" />

    <!-- Botão para gerar o número de matrícula -->
    <Button
        android:id="@+id/buttonGenerateId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gerar Número de Matrícula"
        android:layout_marginTop="16dp" />
</LinearLayout>
