<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/nomePaciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nome do Paciente"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tipoConsulta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo de Consulta"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/dataConsulta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Data da Consulta"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/horaConsulta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hora da Consulta"
        android:textSize="16sp" />
</LinearLayout>
